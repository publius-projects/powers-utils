# XMTP — agent's own XMTP identity key (separate from user wallet keys)
XMTP_WALLET_KEY=0x...
XMTP_DB_ENCRYPTION_KEY=0x...
XMTP_DB_DIRECTORY=./data
XMTP_ENV=production

# RPC endpoints (Alchemy or compatible)
RPC_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
RPC_BASE_SEPOLIA=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
RPC_OPTIMISM_SEPOLIA=https://opt-sepolia.g.alchemy.com/v2/YOUR_KEY
RPC_ARBITRUM_SEPOLIA=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY

# API server
AGENT_API_SECRET=
CONFIG_UI_ORIGIN=http://localhost:4000
PORT=3002

# Session defaults
SESSION_TTL_DEFAULT_MS=28800000
SESSION_TTL_MIN_MS=1800000
SESSION_TTL_MAX_MS=604800000
MAX_TOOL_ROUNDS=8
MAX_HISTORY_TURNS=20
CHAT_RATE_LIMIT_MS=3000
# Enable Claude extended thinking and log reasoning to console (0 = disabled).
# Budget is tokens reserved for thinking; max_tokens is set to budget + 2000.
# THINKING_BUDGET_TOKENS=8000
